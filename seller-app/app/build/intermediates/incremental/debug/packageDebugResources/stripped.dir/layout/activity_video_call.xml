<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Top half: Seller (local) video -->
    <FrameLayout
        android:id="@+id/localVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/purple_700"/>

    <!-- Bottom half: Buyer (remote) video -->
    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Controls bar -->
    <LinearLayout
        android:id="@+id/callControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/tvBuyerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Buyer"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting..."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCaptureAR"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capture for AR"
            android:backgroundTint="#7F77DD"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="End Call"
            android:backgroundTint="#E53935"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</LinearLayout>